# Database Configuration (PostgreSQL)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/unforgettable_evil_bot

# JWT Configuration
SECRET_KEY=your-secret-key-here-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# OpenAI Configuration
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini
OPENAI_MAX_TOKENS=1000

# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here
TELEGRAM_SSL_VERIFY=true

# Redis Configuration
REDIS_URL=redis://localhost:6379
REDIS_ENABLED=true

# WhatsApp Bridge Configuration
WHATSAPP_SESSION_PATH=./whatsapp_sessions
WHATSAPP_BRIDGE_URL=http://localhost:3000

# WhatsApp Business API Configuration
WHATSAPP_ACCESS_TOKEN=your-whatsapp-access-token-here
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id-here
WHATSAPP_BUSINESS_ACCOUNT_ID=your-business-account-id-here

# Admin Configuration
ADMIN_PASSWORD=change-this-to-a-strong-password
ADMIN_USER_ID=1

# Application Configuration
PORT=9876
DEBUG=false
LOG_LEVEL=INFO

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000,http://localhost:9090,http://localhost:9876

# Performance Tuning
MAX_WORKERS=10
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=30

# Data Cleanup (days to retain)
CLEANUP_OLD_MESSAGES_DAYS=30
CLEANUP_OLD_SYSTEM_LOGS_DAYS=7

# Feature Flags
USE_OPTIMIZED_REPOSITORIES=false
SKIP_ASYNC_PROCESSOR=false
